NODE_ENV=development
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
MCP_SERVER_URL=http://localhost:3000/mcp
DATABASE_URL=postgres://mcphub:mcphub@localhost:5432/mcphub
FETCH_TIMEOUT_MS=10000
FETCH_RATE_LIMIT_PER_MINUTE=60

# Optional: enable the sample admin API plugin for local MCP testing.
# SAMPLE_ADMIN_API_BASE_URL=http://localhost:4001
# SAMPLE_ADMIN_API_TOKEN_ENV=SAMPLE_ADMIN_API_TOKEN
# SAMPLE_ADMIN_API_TOKEN=replace-me

# Optional: load trusted precompiled local plugins.
# MCPHUB_PLUGIN_DIR=/opt/mcphub/plugins
# LOCAL_ADMIN_API_TOKEN=replace-me
