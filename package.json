{
  "name": "mcphub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @mcphub/server dev",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "tsx scripts/smoke.ts",
    "fixture:admin": "tsx scripts/admin-fixture.ts",
    "typecheck": "pnpm --filter @mcphub/core build && pnpm --filter @mcphub/db build && pnpm --filter @mcphub/extractors build && pnpm --filter @mcphub/plugins build && pnpm --filter @mcphub/credentials build && pnpm --filter @mcphub/policy build && pnpm --filter @mcphub/api-connector build && pnpm --filter @mcphub/audit build && pnpm --filter @mcphub/mcp build && pnpm -r typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "cheerio": "^1.1.2",
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@mcphub/core": "workspace:*",
    "@mcphub/api-connector": "workspace:*",
    "@mcphub/audit": "workspace:*",
    "@mcphub/credentials": "workspace:*",
    "@mcphub/db": "workspace:*",
    "@mcphub/extractors": "workspace:*",
    "@mcphub/mcp": "workspace:*",
    "@mcphub/plugins": "workspace:*",
    "@mcphub/policy": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@types/chrome": "^0.1.36",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
